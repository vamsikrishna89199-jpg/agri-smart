{
  "cleanUrls": true,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/:match*", "destination": "https://agri-smart-2hhp.onrender.com/api/:match*" },
    { "source": "/", "destination": "/index.html" }
  ]
}
